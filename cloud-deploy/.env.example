# Domain and TLS
PUBLIC_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com
TZ=Asia/Shanghai

# Sub2API admin account, created on first run
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Sub2API runtime secrets. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-fixed-jwt-secret
TOTP_ENCRYPTION_KEY=replace-with-fixed-totp-encryption-key

# Database / Redis
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=sub2api
REDIS_PASSWORD=replace-with-strong-redis-password
BACKUP_RETENTION_DAYS=7
BACKUP_INCLUDE_CADDY_DATA=true
BACKUP_INCLUDE_REDIS_DATA=true

# Docker log rotation. Keeps long-running health checks from filling the disk.
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=5

# Sub2API security for internal adapter channel.
# Keep these true only because nvidia-adapter is on the private Docker network.
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=true
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=true

# NVIDIA Adapter internal upstream channel.
# Add this channel in Sub2API:
#   Base URL: http://nvidia-adapter:8000/v1
#   API Key:  ADAPTER_CLIENT_TOKEN
ADAPTER_ADMIN_TOKEN=replace-with-adapter-admin-token
ADAPTER_CLIENT_TOKEN=sk-adapter-replace-with-internal-token
ADAPTER_REQUEST_TIMEOUT_SECONDS=180
ADAPTER_KEY_COOLDOWN_SECONDS=90
ADAPTER_MAX_RETRIES=10
ADAPTER_KEY_MAX_IN_FLIGHT=1
ADAPTER_KEY_QUEUE_WAIT_SECONDS=30
ADAPTER_MAX_REQUEST_BODY_BYTES=8388608
ADAPTER_ACCESS_LOG_HEALTH=false
NVIDIA_API_KEYS=nvapi-xxx,nvapi-yyy,nvapi-zzz
NVIDIA_ACCOUNT_POOL_FILE=/app/secrets/nvidia-accounts.json

# Sub2API gateway tuning
RUN_MODE=standard
SERVER_MODE=release
OPS_ENABLED=true
DASHBOARD_AGGREGATION_ENABLED=true
GATEWAY_MAX_CONNS_PER_HOST=2048
GATEWAY_MAX_IDLE_CONNS=8192
GATEWAY_MAX_IDLE_CONNS_PER_HOST=4096
GATEWAY_SCHEDULING_FALLBACK_WAIT_TIMEOUT=30s
GATEWAY_SCHEDULING_FALLBACK_MAX_WAITING=100

# HTML injector / Codex compatibility.
# Codex Desktop may send auxiliary Responses calls with a smaller model. These
# settings rewrite matching Codex User-Agent requests back to the intended
# primary model so usage logs and billing stay on one configured Codex model.
CODEX_COMPAT_TARGET_MODEL=gpt-5.5
CODEX_COMPAT_TARGET_REASONING_EFFORT=medium
CODEX_COMPAT_REWRITE_MODELS=gpt-5.4-mini
CODEX_COMPAT_USER_AGENT_MARKER=Codex
STRIP_RESPONSES_IMAGE_TOOL=true

# QR-code payment bridge based on maajiko/Epay's alipaycode + onecode/paypage logic.
# Keep secrets long and random. The watcher can run on a China-side phone/PC/VPS and POST to https://YOUR_DOMAIN/qrpay.
QRPAY_PUBLIC_BASE_URL=
QRPAY_MIN_AMOUNT=2
QRPAY_MAX_AMOUNT=500
QRPAY_QUICK_AMOUNTS=2,10,30,50,100,300,500
QRPAY_QUICK_RECHARGES=2:10,10:72,30:216,50:360,100:777,300:2331,500:3885
QRPAY_ORDER_TIMEOUT_MINUTES=6
QRPAY_MAX_PENDING_ORDERS=1000
QRPAY_AMOUNT_JITTER_CENTS=50
QRPAY_AMOUNT_JITTER_METHODS=wechat_code
QRPAY_ENABLE_ALIPAY_CODE=true
QRPAY_ALIPAY_USER_ID=replace-with-your-alipay-user-id
QRPAY_ENABLE_WECHAT_CODE=false
QRPAY_WECHAT_QR_IMAGE_URL=
QRPAY_WECHAT_PAY_URL=
QRPAY_WATCHER_SECRET=replace-with-long-watcher-secret
QRPAY_ADMIN_SECRET=replace-with-long-admin-secret
QRPAY_VMQ_KEY=
QRPAY_WATCHER_INTERVAL_SECONDS=30
QRPAY_WATCHER_RETRY_INTERVAL_SECONDS=10
QRPAY_WATCHER_MAX_RETRIES=2
QRPAY_WATCHER_RESEND_INTERVAL=10
QRPAY_WATCHER_STALE_AFTER_SECONDS=120
QRPAY_WATCHER_ACTIVE_GRACE_SECONDS=30
QRPAY_ALERT_WEBHOOK_URL=
QRPAY_ALERT_WEBHOOK_SECRET=
QRPAY_PROVIDER_INSTANCE_ID=qrpay-bridge
QRPAY_PROVIDER_KEY=epay_qr
