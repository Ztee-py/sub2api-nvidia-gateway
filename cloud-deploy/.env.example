# Domain and TLS
PUBLIC_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com
TZ=Asia/Shanghai

# Sub2API admin account, created on first run
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Sub2API runtime secrets. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-fixed-jwt-secret
TOTP_ENCRYPTION_KEY=replace-with-fixed-totp-encryption-key

# Database / Redis
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=sub2api
REDIS_PASSWORD=replace-with-strong-redis-password
BACKUP_RETENTION_DAYS=7

# Sub2API security for internal adapter channel.
# Keep these true only because nvidia-adapter is on the private Docker network.
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=true
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=true

# NVIDIA Adapter internal upstream channel.
# Add this channel in Sub2API:
#   Base URL: http://nvidia-adapter:8000/v1
#   API Key:  ADAPTER_CLIENT_TOKEN
ADAPTER_ADMIN_TOKEN=replace-with-adapter-admin-token
ADAPTER_CLIENT_TOKEN=sk-adapter-replace-with-internal-token
ADAPTER_REQUEST_TIMEOUT_SECONDS=180
ADAPTER_KEY_COOLDOWN_SECONDS=90
ADAPTER_MAX_RETRIES=10
ADAPTER_KEY_MAX_IN_FLIGHT=1
ADAPTER_KEY_QUEUE_WAIT_SECONDS=30
ADAPTER_MAX_REQUEST_BODY_BYTES=8388608
NVIDIA_API_KEYS=nvapi-xxx,nvapi-yyy,nvapi-zzz
NVIDIA_ACCOUNT_POOL_FILE=/app/secrets/nvidia-accounts.json

# Sub2API gateway tuning
RUN_MODE=standard
SERVER_MODE=release
OPS_ENABLED=true
DASHBOARD_AGGREGATION_ENABLED=true
GATEWAY_MAX_CONNS_PER_HOST=2048
GATEWAY_MAX_IDLE_CONNS=8192
GATEWAY_MAX_IDLE_CONNS_PER_HOST=4096
GATEWAY_SCHEDULING_FALLBACK_WAIT_TIMEOUT=30s
GATEWAY_SCHEDULING_FALLBACK_MAX_WAITING=100
