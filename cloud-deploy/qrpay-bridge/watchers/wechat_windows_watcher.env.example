QRPAY_BRIDGE_URL=https://Zteapi.com/qrpay
QRPAY_WATCHER_SECRET=replace-with-your-qrpay-watcher-secret
WECHAT_WATCHER_SOURCE=wechat-window-ocr
WECHAT_WATCHER_POLL_INTERVAL=2
WECHAT_WATCHER_HEARTBEAT_INTERVAL=30
# false = try background capture first, then foreground fallback if OCR is blank.
# true  = never bring WeChat to foreground; useful for dedicated watcher desktops, but may fail on some PC WeChat builds.
WECHAT_WINDOW_OCR_NO_FOREGROUND=false
